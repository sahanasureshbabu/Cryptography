#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>
#include <time.h>

int main()
{
    char plain[500];
    char key[]="ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    char cipher[500];
    int freq[26]={0};

    srand(time(NULL));

    for(int i=25;i>0;i--)
    {
        int j=rand()%(i+1);
        char temp=key[i];
        key[i]=key[j];
        key[j]=temp;
    }

    printf("Random Key:\n%s\n\n",key);

    printf("Enter Text:\n");
    fgets(plain,sizeof(plain),stdin);

    for(int i=0;plain[i]!='\0';i++)
    {
        if(isalpha(plain[i]))
        {
            char ch=toupper(plain[i]);
            cipher[i]=key[ch-'A'];
            freq[cipher[i]-'A']++;
        }
        else
            cipher[i]=plain[i];
    }

    cipher[strlen(plain)]='\0';

    printf("\nCipher Text:\n%s\n",cipher);

    printf("\nLetter Frequencies:\n");

    for(int i=0;i<26;i++)
        printf("%c : %d\n",'A'+i,freq[i]);

    return 0;
}
