#include <stdio.h>
#include <string.h>
#include <ctype.h>

void encrypt(char text[], int key)
{
    int i;
    for(i=0;text[i]!='\0';i++)
    {
        if(isalpha(text[i]))
        {
            char base=isupper(text[i])?'A':'a';
            text[i]=((text[i]-base+key)%26)+base;
        }
    }
}

void decrypt(char text[], int key)
{
    encrypt(text,26-key);
}

int main()
{
    char text[100], temp[100];
    int key,i;

    printf("Enter Plaintext: ");
    fgets(text,sizeof(text),stdin);

    printf("Enter Key (0-25): ");
    scanf("%d",&key);

    strcpy(temp,text);
    encrypt(temp,key);
    printf("\nEncrypted Text: %s",temp);

    strcpy(temp,text);
    decrypt(temp,key);
    printf("Decrypted Text: %s",temp);

    printf("\nBrute Force Decryption:\n");

    strcpy(temp,text);
    encrypt(temp,key);

    for(i=1;i<26;i++)
    {
        char trial[100];
        strcpy(trial,temp);
        decrypt(trial,i);
        printf("Key %2d : %s",i,trial);
    }

    return 0;
}
