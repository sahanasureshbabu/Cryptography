#include <stdio.h>
#include <string.h>
#include <ctype.h>

void encrypt(char text[], char key[])
{
    int i,j=0,len=strlen(key);

    for(i=0;text[i]!='\0';i++)
    {
        if(isalpha(text[i]))
        {
            char base=isupper(text[i])?'A':'a';
            text[i]=((text[i]-base)+(toupper(key[j%len])-'A'))%26+base;
            j++;
        }
    }
}

void decrypt(char text[], char key[])
{
    int i,j=0,len=strlen(key);

    for(i=0;text[i]!='\0';i++)
    {
        if(isalpha(text[i]))
        {
            char base=isupper(text[i])?'A':'a';
            text[i]=((text[i]-base)-(toupper(key[j%len])-'A')+26)%26+base;
            j++;
        }
    }
}

int main()
{
    char text[300],enc[300],dec[300],key[30];

    printf("Enter Plaintext: ");
    fgets(text,sizeof(text),stdin);

    printf("Enter Keyword: ");
    scanf("%s",key);

    strcpy(enc,text);
    encrypt(enc,key);

    printf("\nEncrypted Text:\n%s\n",enc);

    strcpy(dec,enc);
    decrypt(dec,key);

    printf("\nDecrypted Text:\n%s\n",dec);

    printf("\nEstimated Key Length: %lu\n",strlen(key));

    return 0;
}
