#include <stdio.h>

int modInverse(int a)
{
    a%=26;
    for(int i=1;i<26;i++)
        if((a*i)%26==1)
            return i;
    return -1;
}

int main()
{
    int key[2][2],inv[2][2];
    char p[3],c[3],d[3];

    printf("Enter 2x2 Key Matrix:\n");
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&key[i][j]);

    int det=(key[0][0]*key[1][1]-key[0][1]*key[1][0])%26;
    if(det<0) det+=26;

    int invDet=modInverse(det);

    if(invDet==-1)
    {
        printf("Matrix is not invertible.\n");
        return 0;
    }

    printf("Enter 2 letters: ");
    scanf("%s",p);

    int x=p[0]-'A';
    int y=p[1]-'A';

    c[0]=((key[0][0]*x+key[0][1]*y)%26)+'A';
    c[1]=((key[1][0]*x+key[1][1]*y)%26)+'A';
    c[2]='\0';

    printf("Encrypted Text: %s\n",c);

    inv[0][0]=(key[1][1]*invDet)%26;
    inv[0][1]=((-key[0][1]+26)*invDet)%26;
    inv[1][0]=((-key[1][0]+26)*invDet)%26;
    inv[1][1]=(key[0][0]*invDet)%26;

    x=c[0]-'A';
    y=c[1]-'A';

    d[0]=((inv[0][0]*x+inv[0][1]*y)%26)+'A';
    d[1]=((inv[1][0]*x+inv[1][1]*y)%26)+'A';
    d[2]='\0';

    printf("Decrypted Text: %s\n",d);

    return 0;
}
